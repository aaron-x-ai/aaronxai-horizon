{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "moonshot-v1-128k",
    "base_url": "https://api.moonshot.cn/v1",
    "api_key_env": "OPENAI_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "languages": [
      "zh",
      "en"
    ]
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "sgl-project",
        "repo": "sglang",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "triton-lang",
        "repo": "triton",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "ollama",
        "repo": "ollama",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "huggingface",
        "repo": "transformers",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "langchain-ai",
        "repo": "langchain",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "meta-llama",
        "repo": "llama-models",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "commaai",
        "repo": "openpilot",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 100
    },
    "rss": [
      {
        "name": "Google AI Blog",
        "url": "https://blog.google/technology/ai/rss/",
        "enabled": true,
        "category": "ai-official"
      },
      {
        "name": "The Verge",
        "url": "https://www.theverge.com/rss/index.xml",
        "enabled": true,
        "category": "tech-news"
      },
      {
        "name": "36氪",
        "url": "https://www.36kr.com/feed",
        "enabled": true,
        "category": "china-tech",
        "fetch_limit": 5
      },
      {
        "name": "阮一峰的网络日志",
        "url": "http://www.ruanyifeng.com/blog/atom.xml",
        "enabled": true,
        "category": "tech-weekly"
      },
      {
        "name": "GitHub Trending - Daily",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending"
      }
    ],
    "reddit": {
      "enabled": false,
      "subreddits": [],
      "users": [],
      "fetch_comments": 10
    },
    "telegram": {
      "enabled": true,
      "channels": [
        {
          "channel": "zaihuapd",
          "enabled": true,
          "fetch_limit": 20
        }
      ]
    },
    "twitter": {
      "enabled": true,
      "users": [
        "karpathy"
      ],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    }
  },
  "filtering": {
    "ai_score_threshold": 8.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "last",
    "platform": "feishu",
    "layout": "collapsible",
    "fallback_layout": "markdown",
    "languages": [
      "zh"
    ],
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}